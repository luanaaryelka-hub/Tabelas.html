<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estabelecimentos</title>

    <style>
        body {
            font-family: Arial, sans-serif;
        }

        table {
            border-collapse: collapse;
            width: 450px;
        }

        td {
            /* LINHAS HORIZONTAIS (mais claras) */
            border-top: 1px solid #7aace9;
            border-bottom: 1px solid #7aace9;

            /* LINHA VERTICAL (mais escura) */
            border-right: 1px solid #7aace9;

            padding: 10px;
        }

        /* Remove borda da esquerda */
        td:first-child {
            border-left: none;
            background-color: #f2f2f2; /* cinza claro da coluna */
            font-weight: bold;
        }

        /* Alinhamento dos números */
        td:not(:first-child) {
            text-align: right;
        }

    </style>
</head>

<body>

    <table>

        <tr>
            <td>Total</td>
            <td>953.260</td>
            <td>721.291</td>
        </tr>

        <tr>
            <td>Estabelecimento<br>de ensino</td>
            <td>7.875</td>
            <td>6.444</td>
        </tr>

        <tr>
            <td>Estabelecimento<br>de saúde</td>
            <td>2.780</td>
            <td>2.507</td>
        </tr>

        <tr>
            <td>Estabelecimento<br>religioso</td>
            <td>50.729</td>
            <td>38.393</td>
        </tr>

        <tr>
            <td>Estabelecimento<br>agropecuário</td>
            <td>938</td>
            <td>629</td>
        </tr>

    </table>

</body>
</html>
